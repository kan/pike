{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main",
    "project-*"
  ],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:allow-set-title",
    "core:window:allow-set-focus",
    "window-state:default",
    "updater:default",
    "process:default"
  ]
}
