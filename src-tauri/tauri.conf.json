{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pike",
  "version": "0.3.11",
  "identifier": "com.pike.dev",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Pike",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "windows": {
      "nsis": {
        "installerHooks": "nsis/hooks.nsi"
      }
    },
    "createUpdaterArtifacts": true,
    "externalBin": [
      "binaries/rg"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY5QjdDQURGMTkxNTFDQ0MKUldUTUhCVVozOHEzYVlwOW5PUHYyL0FaQzhNaXI2VEM1U2luTXNPNFdWT2JPbFlQemd4dXVxd3EK",
      "endpoints": [
        "https://github.com/kan/pike/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
